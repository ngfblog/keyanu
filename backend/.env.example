# Copy to .env and change every value before deploying to production.

# Signs session JWTs. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-please-this-is-not-secure-for-production-use

# Derives the key used to encrypt credential secrets and TOTP secrets at rest.
# Generate with: openssl rand -hex 32
# WARNING: changing this after credentials exist makes them unreadable.
ENCRYPTION_KEY=change-me-please-this-is-not-secure-for-production-use

# Bootstrap admin account, created automatically on first run with
# must_change_password=true -- you'll be required to set a new password on
# first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Where the SQLite database and uploaded files are stored.
DATA_DIR=/data

# Default idle session timeout (minutes) for newly created users. Each user
# can change their own value under Settings > Security > Session timeout.
DEFAULT_SESSION_TIMEOUT_MINUTES=720

ENVIRONMENT=production
