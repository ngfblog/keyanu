# ------------------------------------------------------------------------
# LOCAL DEVELOPMENT ONLY.
#
# This file is for running the backend directly with `uvicorn` on your own
# machine (see "Running for local development" in the root README). It is
# NOT used for production deployment.
#
# For production:
#   - Unraid: set these as environment variables in the Unraid template
#     (Docker tab -> keyanu-backend -> edit each field). No file editing
#     required.
#   - Docker Compose / plain `docker run`: pass these as real environment
#     variables (`docker run -e SECRET_KEY=... ...`, an exported shell
#     environment, or your orchestrator's secrets/env mechanism). See the
#     root README's "Quick start" and "Unraid" sections.
# ------------------------------------------------------------------------

# Copy to .env (in this backend/ folder) for local development.

# Signs session JWTs. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-please-this-is-not-secure-for-production-use

# Derives the key used to encrypt credential secrets and TOTP secrets at rest.
# Generate with: openssl rand -hex 32
# WARNING: changing this after credentials exist makes them unreadable.
ENCRYPTION_KEY=change-me-please-this-is-not-secure-for-production-use

# Bootstrap admin account, created automatically on first run with
# must_change_password=true -- you'll be required to set a new password on
# first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Where the SQLite database and uploaded files are stored.
DATA_DIR=/data

# Default idle session timeout (minutes) applied to the admin account on
# first boot. Each user can change their own value later under
# Settings > Security > Session timeout.
DEFAULT_SESSION_TIMEOUT_MINUTES=720

ENVIRONMENT=development
